rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - inventoryQuantity: number (required)
    //
    // Collection: import_slips
    // Document ID: {slipId}
    // Fields:
    //   - id: string (required)
    //   - productId: string (required)
    //   - quantity: number (required)
    //   - importPrice: number (required)
    //   - totalPrice: number (required)
    //   - importDate: string (required)
    //
    // Collection: expenses
    // Document ID: {expenseId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - amount: number (required)
    //   - expenseDate: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email in ["hoangthanhgolle@gmail.com", "alostore6688@gmail.com", "admin@gmail.com"] && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidProduct(data) {
      return hasOnlyAllowedFields(['id', 'name', 'slug', 'price', 'originalPrice', 'discountPercentage', 'image', 'images', 'category', 'brand', 'specs', 'variants', 'inStock', 'isUsed', 'description', 'inventoryQuantity', 'offers', 'reviews']) &&
             data.id is string && data.name is string && data.slug is string && data.price is number && data.image is string &&
             data.category is string && data.brand is string && data.inStock is bool;
    }

    function isValidImportSlip(data) {
      return hasOnlyAllowedFields(['id', 'productId', 'quantity', 'importPrice', 'totalPrice', 'importDate']) &&
             data.id is string && data.productId is string && data.quantity is number && data.quantity > 0 &&
             data.importPrice is number && data.importPrice >= 0 && data.totalPrice is number && data.totalPrice >= 0 &&
             data.importDate is string;
    }

    function isValidExpense(data) {
      return hasOnlyAllowedFields(['id', 'name', 'amount', 'expenseDate']) &&
             data.id is string && data.name is string && data.amount is number && data.amount >= 0 &&
             data.expenseDate is string;
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['id', 'name', 'username', 'email', 'role', 'dob']) &&
             data.id is string && data.name is string && data.email is string && data.role in ['user', 'admin'];
    }

    // Rules
    match /users/{userId} {
      // Allow users to read their own data, allow admin to read all, allow checking for duplicate username
      allow read: if isAuthenticated();
      // Allow users to create/update their own data
      allow create, update: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /import_slips/{slipId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidImportSlip(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidExpense(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /trade_in_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
